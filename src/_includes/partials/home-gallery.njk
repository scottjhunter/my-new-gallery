<section class="home-gallery" aria-labelledby="latest-gallery">
  <div class="home-gallery-header">
    <h2 id="latest-gallery" class="h1">Latest Gallery Images</h2>
  </div>
  <div class="gallery">
    <ul class="image-grid">
      {% for image in gallery %}
      {% if loop.index <= 6 %}
      <li class="image-container">
        <a
          href="/gallery/{{ image.title | safeSlug }}"
          aria-label="Gallery image {{ image.title }}"
        >
          {% img
            src=image.src,
            alt=image.alt,
            className="grid-image",
            sizes="(min-width: 600px) 50vw, (min-width: 800px) 100vw, 33.3vw"
          %}
        </a>
      </li>
      {% endif %}
      {% endfor %}
    </ul>
  </div>
  <div class="home-gallery-footer">
    <p><a href="/gallery/">View gallery</a></p>
  </div>
</section>
