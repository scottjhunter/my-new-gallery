---
title: News | Scott Hunter
meta_desc: A curated feed of articles at the intersection of AI, ethics, consciousness, art, and mysticism.
url: https://scottjhunter.org/news/
img: /images/blog.png
alt: Blog banner image
eleventyNavigation:
  key: News
  order: 4
heading: News
permalink: "/news/"
layout: main.njk
---
{% set midpoint = (feed.items.length / 2) | round(0, "ceil") %}
{% set leftItems = feed.items.slice(0, midpoint) %}
{% set rightItems = feed.items.slice(midpoint) %}

<section class="feed-page">
  <header class="feed-page-header">
    <h1>{{ heading }}</h1>
    <p class="feed-page-subtitle">Recent news articles featuring a blend of AI, ethics, consciousness, art, or mysticism. Updated twice daily.</p>
    {% if feed.generatedDisplay %}
    <p class="feed-generated">Updated {{ feed.generatedDisplay }}</p>
    {% endif %}
  </header>

  {% if feed.items.length %}
  <div class="feed-grid" role="list">
    <div class="feed-column" role="listitem">
      {% for item in leftItems %}
      <article class="feed-item">
        <h2 class="feed-item-title"><a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a></h2>
        <p class="feed-item-meta">{{ item.source }} {% if item.publishedDisplay %}| {{ item.publishedDisplay }}{% endif %}</p>
      </article>
      {% endfor %}
    </div>

    <div class="feed-column" role="listitem">
      {% for item in rightItems %}
      <article class="feed-item">
        <h2 class="feed-item-title"><a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a></h2>
        <p class="feed-item-meta">{{ item.source }} {% if item.publishedDisplay %}| {{ item.publishedDisplay }}{% endif %}</p>
      </article>
      {% endfor %}
    </div>
  </div>
  {% else %}
  <p class="feed-empty">No feed stories yet. The next automated run will populate this page.</p>
  {% endif %}

  {% if feed.failures.length %}
  <details class="feed-failures">
    <summary>Source fetch warnings ({{ feed.failures.length }})</summary>
    <ul>
      {% for failure in feed.failures %}
      <li><code>{{ failure.query }}</code>: {{ failure.error }}</li>
      {% endfor %}
    </ul>
  </details>
  {% endif %}
</section>
